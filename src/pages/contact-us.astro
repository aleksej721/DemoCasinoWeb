---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
---

<BaseLayout title={`Contact us | ${site.brand}`} description={`Contact page for ${site.brand}.`}>
  <Header />
  <main class="container section policy">
    <h1>Contact us</h1>
    <p>Demo contact page. In production, connect this to the approved support email or form flow.</p>
  </main>
  <Footer />
</BaseLayout>

<style>
  .policy {
    min-height: 48vh;
  }
</style>
