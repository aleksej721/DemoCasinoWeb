---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { site } from "../data/site";
---

<BaseLayout title={`Responsible Gambling | ${site.brand}`} description={`Responsible play page for ${site.brand}.`}>
  <Header />
  <main class="container section policy">
    <h1>Responsible Gambling</h1>
    <p>18+ only. This demo keeps responsible-play messaging visible and configurable per market.</p>
  </main>
  <Footer />
</BaseLayout>

<style>
  .policy {
    min-height: 48vh;
  }
</style>
