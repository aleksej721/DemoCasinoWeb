---
import { slots } from "../data/slots";
import TrackButton from "./TrackButton.astro";
---

<section class="section">
  <div class="container">
    <div class="slots-head">
      <h2>New slots</h2>
      <div class="arrow-pair">
        <button type="button" class="arrow-button" data-scroll="left" aria-label="Scroll left">←</button>
        <button type="button" class="arrow-button" data-scroll="right" aria-label="Scroll right">→</button>
      </div>
    </div>

    <div class="slot-row" aria-label="New slot games">
      {
        slots.map((slot) => (
          <article class="slot-card">
            <a class="slot-media" href={slot.link} aria-label={`Open ${slot.title}`}>
              <img src={slot.image} alt={`${slot.title} slot artwork`} loading="lazy" decoding="async" />
              <span class={`slot-tag ${slot.gradient}`}>{slot.tag}</span>
            </a>

            <div class="slot-info">
              <strong>{slot.title}</strong>
              <TrackButton href={slot.link} text="Play" variant="secondary" event="slot_click" className="slot-button" />
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  const slotRow = document.querySelector(".slot-row");
  const arrowButtons = document.querySelectorAll(".arrow-button");

  if (slotRow && arrowButtons.length) {
    arrowButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const direction = button.dataset.scroll;
        const scrollAmount = slotRow.clientWidth * 0.8;

        slotRow.scrollBy({
          left: direction === "left" ? -scrollAmount : scrollAmount,
          behavior: "smooth"
        });
      });
    });
  }
</script>

<style>
  .slots-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 18px;
  }

  .arrow-pair {
    display: none;
    gap: 10px;
  }

  .arrow-button {
    display: grid;
    width: 46px;
    height: 46px;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background: var(--panel-2);
    color: var(--muted);
    font-size: 1.15rem;
    font-weight: 800;
    cursor: pointer;
    transition: background 160ms ease, border-color 160ms ease, color 160ms ease;
  }

  .arrow-button:hover,
  .arrow-button:focus-visible {
    border-color: rgba(255, 255, 255, 0.22);
    background: #29293b;
    color: var(--text);
    outline: none;
  }

  .slot-row {
    display: grid;
    grid-auto-columns: minmax(245px, 31%);
    grid-auto-flow: column;
    gap: 18px;
    overflow-x: auto;
    padding: 2px 2px 14px;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    scrollbar-color: rgba(255, 255, 255, 0.24) transparent;
  }

  .slot-card {
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    background: #12121e;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.18);
    scroll-snap-align: start;
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .slot-media {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.08), transparent),
      #202033;
  }

  .slot-media::after {
    position: absolute;
    inset: auto 0 0;
    height: 44%;
    background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.7));
    content: "";
    pointer-events: none;
  }

  .slot-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 220ms ease, filter 220ms ease;
  }

  .slot-tag {
    position: absolute;
    left: 14px;
    bottom: 14px;
    z-index: 1;
    border: 1px solid rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    padding: 7px 12px;
    background: rgba(10, 10, 18, 0.68);
    color: white;
    font-size: 0.82rem;
    font-weight: 800;
    line-height: 1;
    backdrop-filter: blur(12px);
    box-shadow: 0 8px 18px rgba(0, 0, 0, 0.25);
  }

  .slot-tag.from-gold {
    background: linear-gradient(135deg, rgba(245, 158, 11, 0.92), rgba(124, 45, 18, 0.92));
  }

  .slot-tag.from-blue {
    background: linear-gradient(135deg, rgba(37, 99, 235, 0.92), rgba(17, 24, 39, 0.92));
  }

  .slot-tag.from-red {
    background: linear-gradient(135deg, rgba(239, 68, 68, 0.92), rgba(88, 28, 135, 0.92));
  }

  .slot-tag.from-purple {
    background: linear-gradient(135deg, rgba(124, 58, 237, 0.92), rgba(17, 24, 39, 0.92));
  }

  .slot-tag.from-cyan {
    background: linear-gradient(135deg, rgba(6, 182, 212, 0.92), rgba(15, 23, 42, 0.92));
  }

  .slot-tag.from-green {
    background: linear-gradient(135deg, rgba(22, 163, 74, 0.92), rgba(15, 23, 42, 0.92));
  }

  .slot-info {
    display: flex;
    min-height: 120px;
    flex-direction: column;
    gap: 14px;
    justify-content: space-between;
    padding: 18px;
  }

  .slot-info strong {
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.15;
  }

  .slot-button {
    width: 100%;
  }

  @media (hover: hover) {
    .slot-card:hover {
      border-color: rgba(255, 255, 255, 0.24);
      box-shadow: 0 22px 52px rgba(0, 0, 0, 0.26);
      transform: translateY(-3px);
    }

    .slot-card:hover .slot-media img {
      filter: saturate(1.08) brightness(1.04);
      transform: scale(1.045);
    }

    .slot-button {
      opacity: 0;
      transform: translateY(4px);
    }

    .slot-card:hover .slot-button {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (min-width: 760px) {
    .arrow-pair {
      display: flex;
    }
  }

  @media (min-width: 1080px) {
    .slot-row {
      grid-auto-columns: minmax(260px, 24%);
    }
  }
</style>
