---
import { site } from "../data/site";
import TrackButton from "./TrackButton.astro";
---

<section class="hero section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">{site.heroEyebrow}</p>
      <h1>{site.heroTitle}</h1>
      <p class="hero-text">{site.heroText}</p>
      <div class="hero-actions">
        <TrackButton href={site.links.register} text="Start playing" event="register" />
        <TrackButton href={site.links.app} text="Download app" variant="secondary" event="app" />
      </div>
    </div>

    <div class="hero-art" aria-label="Bikers From Sklep Casino hero bonus image">
      <img class="hero-image" src={site.bonusImage} alt="Bikers bonus art" />
      <div class="hero-art-overlay"></div>
      <div class="hero-art-glow"></div>
      <div class="ticket">
        <span>250%</span>
        <strong>Welcome Pack</strong>
        <small>up to {site.currency}1,200</small>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: 48px;
  }

  .hero-grid {
    display: grid;
    gap: 24px;
  }

  .hero-copy {
    border-radius: 8px;
    padding: clamp(28px, 5vw, 54px);
    background:
      linear-gradient(135deg, rgba(255, 63, 85, 0.98), rgba(255, 159, 28, 0.82)),
      #20202f;
  }

  .eyebrow {
    display: inline-flex;
    border: 1px solid rgba(255, 255, 255, 0.46);
    border-radius: 999px;
    padding: 7px 12px;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .hero-text {
    max-width: 720px;
    color: rgba(255, 255, 255, 0.88);
    font-size: 1.05rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  .hero-art {
    position: relative;
    min-height: 420px;
    overflow: hidden;
    border-radius: 16px;
    background: #0d0d18;
  }

  .hero-art::before,
  .hero-art::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero-art::before {
    background: radial-gradient(circle at top left, rgba(0, 0, 0, 0.15), transparent 32%);
  }

  .hero-art::after {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.12), rgba(0, 0, 0, 0.6));
  }

  .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .hero-art-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.15), rgba(0, 0, 0, 0.5));
    pointer-events: none;
  }

  .hero-art-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at center, rgba(255, 255, 255, 0.08), transparent 30%);
    pointer-events: none;
  }

  .orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(2px);
  }

  .orb.one {
    width: 160px;
    height: 160px;
    right: 16%;
    top: 18%;
    background: radial-gradient(circle, rgba(255, 159, 28, 0.9), transparent 68%);
  }

  .orb.two {
    width: 220px;
    height: 220px;
    right: -40px;
    bottom: -70px;
    background: radial-gradient(circle, rgba(255, 63, 85, 0.72), transparent 68%);
  }

  .ticket {
    position: absolute;
    left: 26px;
    bottom: 26px;
    display: grid;
    gap: 6px;
    width: min(280px, calc(100% - 52px));
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 8px;
    padding: 22px;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(12px);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
  }

  .ticket span,
  .ticket strong,
  .ticket small {
    color: #fff;
  }

  .ticket span {
    font-size: 3rem;
    font-weight: 900;
    line-height: 1;
    text-shadow: 0 2px 12px rgba(0, 0, 0, 0.45);
  }

  .ticket strong {
    font-size: 1.2rem;
    letter-spacing: 0.06em;
  }

  .ticket small {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.95rem;
  }

  @media (min-width: 980px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.8fr) minmax(320px, 0.8fr);
    }

    .hero-art {
      min-height: 520px;
    }
  }
</style>
